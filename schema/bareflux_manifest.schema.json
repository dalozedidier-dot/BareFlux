{
  "title": "BareFlux orchestration manifest",
  "type": "object",
  "required": [
    "schema_version",
    "tool",
    "version",
    "created_at_utc",
    "status",
    "strict",
    "modules",
    "datasets",
    "outputs",
    "strict_errors"
  ],
  "properties": {
    "schema_version": {"const": "bareflux.manifest.v1"},
    "tool": {"const": "BareFlux"},
    "version": {"type": "string"},
    "created_at_utc": {"type": "string"},
    "status": {"enum": ["PASS", "FAIL"]},
    "strict": {"type": "boolean"},
    "failure_step": {"type": "string"},
    "modules": {"type": "object"},
    "datasets": {"type": "object"},
    "outputs": {"type": "object"},
    "strict_errors": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
